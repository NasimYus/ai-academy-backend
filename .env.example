# --- App ---
APP_NAME="AI Academy API"
ENVIRONMENT=development
DEBUG=true

# --- Database ---
# async driver (asyncpg)
DATABASE_URL=postgresql+asyncpg://aiacademy:aiacademy@localhost:5432/aiacademy

# --- Auth / JWT ---
SECRET_KEY=change-me-in-production
