# --- App ---
APP_NAME="AI Academy API"
ENVIRONMENT=development
DEBUG=true

# --- Database ---
# async driver (asyncpg)
DATABASE_URL=postgresql+asyncpg://aiacademy:aiacademy@localhost:5432/aiacademy

# --- Auth / JWT ---
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# --- CORS (frontend SPA origins, comma-separated) ---
CORS_ORIGINS_RAW=http://localhost:3000,http://localhost:5173
# Regex for local dev origins (any localhost/127.0.0.1 port). Add prod domains to CORS_ORIGINS_RAW.
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
